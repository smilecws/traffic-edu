rules_version = '2';

// Firestore 보안 규칙.
//   - 글로벌 통계 집계는 GitHub Actions 서버사이드(aggregate_stats.js)가 서비스 계정으로 수행.
//   - user_answers: 클라이언트가 세션 로그를 create. 운영자가 콘솔에서 조회.
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자별 풀이 이력 — 운영자가 Firebase 콘솔에서만 조회.
    // 클라이언트는 자기 uid 의 세션만 create 가능. read/update/delete 모두 차단.
    match /user_answers/{uid}/sessions/{sid} {
      allow read: if false;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if false;
    }
  }
}
